# ── Python ──
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/
.pytest_cache/
.ruff_cache/

# ── Node / 프론트엔드 ──
node_modules/
dist/
dist-ssr/
*.local

# ── 환경 (시크릿) ──
.env
.env.*
!.env.example

# ── 데이터 (pola — docker volume·대용량 raw) ──
pola/data/*
# 단, LLM 추출 산출(jsonl)은 재현 픽스처로 커밋 → 다른 사람이 LLM 없이 graph_load 로 그래프 재현
!pola/data/4_dbGoldTest/
pola/data/4_dbGoldTest/*
!pola/data/4_dbGoldTest/news_extracts/
pola/data/4_dbGoldTest/news_extracts/*
!pola/data/4_dbGoldTest/news_extracts/*.jsonl
pola/.tmp_crawl_*/
pola/.playwright-mcp/

# ── 재생성 가능한 배치 입력 (export_batches.py 로 재생성) ──
pola/scripts/news_graph/*/

# ── Claude (워크플로 스크립트·로컬 에이전트 산출·로컬 지침) ──
.claude/
/CLAUDE.md

# ── DB 덤프 산출물 (별도 전달 — 레포에 커밋 안 함) ──
/dump/out/

# ── OS / IDE ──
.DS_Store
Thumbs.db
.idea/
.vscode/
/docs/개인공부