
# ========================================
# LLM via apimaker (in-process Gemini CLI 구독 세션)
# ========================================
# LLM 은 apimaker 를 직접 import 해 같은 프로세스 안에서 로컬 `gemini` CLI 로 호출한다.
# 별도 서버 불필요. (API 키가 아니라 로컬 `gemini` CLI OAuth 로 인증 — GEMINI_API_KEY 불필요)
# 전제: `gemini` CLI 설치 + 1회 로그인(Google AI Pro/Ultra 계정).
APIMAKER_PROVIDER=gemini
# 모델 미지정 시 gemini CLI 기본값 사용 (예: gemini-2.5-flash, gemini-2.5-pro)
# APIMAKER_MODEL=gemini-2.5-flash
# APIMAKER_TIMEOUT=180
# apimaker 패키지 경로 자동 탐지(repo 내 apimaker-project/src). 다른 위치면 지정:
# APIMAKER_SRC_PATH=C:\path\to\apimaker-project\src

# ========================================
# LLM API Keys (구버전 — 현재 미사용, 참고용)
# ========================================
# 발급받은 API 키를 입력하세요 (절대 실제 키를 커밋하지 마세요)
OPENAI_API_KEY=your_openai_api_key_here
# GEMINI_API_KEY=your_gemini_api_key_here

# ========================================
# Memory & Database (대화 문맥 및 세션 유지)
# ========================================

# RDBMS / NoSQL 연결 정보
DATABASE_URL=your_database_connection_string

# ========================================
# Qdrant (벡터 검색, 읽기 전용 조회)
# ========================================
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_COLLECTION=polaris-chunks

# 3-DB 직결 (rdb_client / vector_store / graph_client / 관리자 db-status 가 사용)
MARIADB_HOST=localhost
MARIADB_PORT=3307
MARIADB_USER=polaris
MARIADB_PASSWORD=polaris_dev_only
MARIADB_DATABASE=polaris
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=polaris_dev_only

# ========================================
# 적재 파이프라인 관리자 콘솔
# ========================================
# 관리자 인증 토큰 (X-Admin-Token 헤더). openssl rand -hex 32 로 발급 권장
ADMIN_TOKEN=change-me
# pipeline_scripts/ 절대경로. 미설정 시 repo 의 pipeline_scripts/ 사용
PIPELINE_WORKDIR=
# DART OpenAPI key (fetch 단계)
DART_API_KEY=
# extract 단계에서 provider=claude 선택 시 필요
ANTHROPIC_API_KEY=
# extract/ollama 임베딩 베이스
OLLAMA_BASE=http://localhost:11434
